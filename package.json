{
  "name": "appium-xcuitest-driver",
  "version": "11.17.7",
  "description": "Appium driver for iOS using XCUITest for backend",
  "keywords": [
    "appium",
    "ios",
    "webdriveragent",
    "xctest",
    "xcuitest"
  ],
  "bugs": {
    "url": "https://github.com/appium/appium-xcuitest-driver/issues"
  },
  "license": "Apache-2.0",
  "author": "Appium Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/appium/appium-xcuitest-driver.git"
  },
  "bin": {},
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib",
    "scripts",
    "build/lib",
    "!.DS_Store",
    "CHANGELOG.md",
    "LICENSE",
    "npm-shrinkwrap.json"
  ],
  "main": "./build/lib/index.js",
  "types": "./build/lib/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "npm run build -- --clean",
    "dev": "npm run build -- --watch",
    "build:docs": "appium-docs build",
    "dev:docs": "appium-docs build --serve",
    "publish:docs": "appium-docs build --deploy --push -b docs-site -m 'docs: auto-build docs for appium-xcuitest-driver@%s' --alias latest",
    "lint": "eslint .",
    "lint:commit": "commitlint",
    "lint:fix": "npm run lint -- --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "install-docs-deps": "appium-docs init --no-mkdocs",
    "prepare": "npm run rebuild",
    "rebuild": "npm run clean; npm run build",
    "test": "node --test --test-force-exit --test-timeout=60000 \"./build/test/unit/**/*.spec.js\"",
    "e2e-test": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/**/*.spec.js\"",
    "e2e-test:basic": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/basic/**/*.spec.js\"",
    "e2e-test:device": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/device/**/*.spec.js\"",
    "e2e-test:driver": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/driver/**/*.spec.js\"",
    "e2e-test:long": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/long/**/*.spec.js\"",
    "e2e-test:parallel": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/parallel/**/*.spec.js\"",
    "e2e-test:web": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/web/**/*.spec.js\"",
    "e2e-test:native-web-tap": "node --test --test-force-exit --test-timeout=600000 \"./build/test/functional/web/safari-nativewebtap*.spec.js\"",
    "start": "appium --relaxed-security --port 4567 --keep-alive-timeout 1200"
  },
  "dependencies": {
    "@appium/css-locator-to-native": "^1.0.1",
    "@appium/strongbox": "^1.0.0-rc.1",
    "@colors/colors": "^1.6.0",
    "appium-ios-device": "^3.1.12",
    "appium-ios-simulator": "^8.2.0",
    "appium-remote-debugger": "^15.7.3",
    "appium-webdriveragent": "^15.1.6",
    "appium-xcode": "^6.0.2",
    "async-lock": "^1.4.0",
    "asyncbox": "^6.3.0",
    "axios": "^1.4.0",
    "commander": "^14.0.1",
    "dayjs": "^1.11.21",
    "js2xmlparser2": "^0.x",
    "lru-cache": "^11.1.0",
    "node-devicectl": "^1.1.0",
    "node-simctl": "^8.1.1",
    "portscanner": "^2.2.0",
    "semver": "^7.5.4",
    "teen_process": "^4.0.4",
    "winston": "^3.17.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@appium/docutils": "^2.4.0",
    "@appium/eslint-config-appium-ts": "^3.0.0",
    "@appium/tsconfig": "^1.0.0-rc.1",
    "@appium/types": "^1.5.0",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^10.0.1",
    "@types/async-lock": "1.4.2",
    "@types/chai": "5.2.3",
    "@types/chai-as-promised": "8.0.2",
    "@types/node": "^26.0.0",
    "@types/pem": "1.14.4",
    "@types/portscanner": "^2.1.1",
    "@types/semver": "7.7.1",
    "@types/sinon": "22.0.0",
    "chai": "^6.0.0",
    "chai-as-promised": "^8.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "oxfmt": "^0.x",
    "pem": "^1.14.8",
    "semantic-release": "^25.0.2",
    "sharp": "^0.x",
    "sinon": "^22.0.0",
    "typescript": "^6.0.2",
    "webdriverio": "^9.4.1"
  },
  "peerDependencies": {
    "appium": "^3.0.0-rc.2"
  },
  "optionalDependencies": {
    "appium-ios-remotexpc": "^5.6.1"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "appium": {
    "driverName": "xcuitest",
    "automationName": "XCUITest",
    "platformNames": [
      "iOS",
      "tvOS"
    ],
    "mainClass": "XCUITestDriver",
    "scripts": {
      "build-wda": "./scripts/build-wda.mjs",
      "open-wda": "./scripts/open-wda.mjs",
      "tunnel-creation": "./scripts/tunnel-creation.mjs",
      "download-wda": "./scripts/download-wda.mjs",
      "download-wda-sim": "./scripts/download-wda-sim.mjs",
      "sign-wda": "./scripts/sign-wda.mjs",
      "image-mounter": "./scripts/image-mounter.mjs",
      "list-real-devices": "./scripts/list-real-devices.mjs",
      "cleanup-videos": "./scripts/cleanup-videos.mjs",
      "pair-appletv": "./scripts/pair-appletv.mjs"
    },
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema",
      "type": "object",
      "properties": {
        "webdriveragent-port": {
          "appiumCliDest": "wdaLocalPort",
          "default": 8100,
          "description": "Local port used for communication with WebDriverAgent",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "title": "XCUITest Driver Configuration",
      "description": "Appium configuration schema for the XCUITest driver."
    },
    "doctor": {
      "checks": [
        "./build/lib/doctor/required-checks.js",
        "./build/lib/doctor/optional-checks.js"
      ]
    }
  }
}
